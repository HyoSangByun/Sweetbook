SERVER_PORT=8080

SWEETBOOK_API_BASE_URL=https://api-sandbox.sweetbook.com/v1
SWEETBOOK_SANDBOX_API_KEY=your-sandbox-api-key
SWEETBOOK_BOOK_SPEC_UID=your-book-spec-uid
SWEETBOOK_CONNECT_TIMEOUT=3s
SWEETBOOK_READ_TIMEOUT=10s

JWT_SECRET=replace-with-32-bytes-or-more-secret
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
PHOTO_STORAGE_DIR=uploads/activity-photos
PHOTO_MAX_FILE_SIZE_BYTES=10485760

DB_URL=jdbc:h2:mem:sweetbook;MODE=MySQL;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_USERNAME=sa
DB_PASSWORD=
